{
  "name": "p10pro",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "bash ./scripts/dev-check.sh && vite",
    "build:electron": "node ./scripts/build-electron.mjs",
    "electron:dev": "npm run build:electron && (npm run dev & NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .)",
    "electron:start": "npm run build && electron .",
    "build": "tsc --noEmit && vite build && npm run build:electron",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md}\"",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:mac:intel": "electron-builder --mac --x64",
    "build:mac:silicon": "electron-builder --mac --arm64",
    "build:win": "electron-builder --win --x64",
    "build:win:portable": "electron-builder --win portable",
    "build:linux": "electron-builder --linux",
    "build:linux:deb": "electron-builder --linux deb",
    "build:linux:appimage": "electron-builder --linux AppImage",
    "validate:lockfile": "bash ../scripts/validate-lockfile.sh",
    "validate:build": "bash ../scripts/validate-build.sh",
    "pretest": "npm run validate:lockfile",
    "prebuild:native": "node scripts/enforce-arm64.js",
    "build:native": "npm run prebuild:native && ./scripts/idempotent-rebuild.sh",
    "electron:build:mac": "npm run build:native && electron-builder --mac --arm64",
    "clean:idempotent": "rm -rf dist build && rm -rf ~/.electron-gyp && node -e \"console.log('[INFO] Caché nativa limpiada. Estado cero garantizado.')\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "electron": "41.2.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.59.3",
    "vite": "5.4.21"
  },
  "build": {
    "appId": "com.kolicode.app",
    "productName": "KoliCode",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Graphics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "axios": "^1.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --cache --fix",
    "*.{ts,tsx,js,jsx,css,md}": "prettier --write"
  }
}
