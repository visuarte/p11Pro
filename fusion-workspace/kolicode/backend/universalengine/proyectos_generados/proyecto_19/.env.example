# Variables de entorno ejemplo
DATABASE_URL=postgresql://usuario:password@localhost:5432/imprenta
JWT_SECRET=supersecreto
API_KEY=tu_api_key
CORS_ORIGINS=*

# JWT configuration
JWT_ISSUER=imprenta-erp-api
