## .env.example — variables de entorno de ejemplo (NO COMMIT). Copia este archivo a .env y ajusta valores.

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=ciberpunk
DB_USER=postgres
DB_PASSWORD=postgres

# JDBC URL (opcional, si se define tiene prioridad)
#JDBC_DATABASE_URL=jdbc:postgresql://db:5432/ciberpunk

# Control DB init (1 = skip creating tables via Exposed)
SKIP_DB_INIT=0

# Application
PORT=8040
USE_THREE_JS=true
ENABLE_TAILWIND_DIRECTIVES=false

# Kotguaicli integration (optional)
KOTGUAICLI_PATH=../kotguaicli
#KOTGUAICLI_AUTH_TOKEN=

