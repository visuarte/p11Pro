            "value": "{{kotguaicliAuthToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"port\":8090}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/kotguaicli/serve-docs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "kotguaicli",
            "serve-docs"
          ]
        }
      }
