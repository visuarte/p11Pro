      }
    },
    {
      "name": "Kotguaicli generate docs",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-KOTGUAICLI-AUTH",
            "value": "{{kotguaicliAuthToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/kotguaicli/generate-docs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "kotguaicli",
            "generate-docs"
          ]
        }
      }
    },
