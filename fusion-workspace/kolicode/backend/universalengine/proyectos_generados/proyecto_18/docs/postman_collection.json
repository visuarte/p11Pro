          "raw": "{{baseUrl}}/api/v1/checklist",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "checklist"
          ]
        }
      }
    },
    {
      "name": "Get checklist",
      "request": {
        "method": "GET",
        "header": [],
