# Copy this file into the clone as .env and adjust values if needed.
COMPOSE_PROJECT_NAME=laprint_copia_1

API_CONTAINER_NAME=motor-ktor-laprint-copia-1
WEB_CONTAINER_NAME=interfaz-web-laprint-copia-1
DB_CONTAINER_NAME=base-datos-laprint-copia-1

API_HOST_PORT=8081
WEB_HOST_PORT=3001
DB_HOST_PORT=5433

DB_NAME=universal_db_laprint_copia_1
DB_USER=admin
DB_PASS=universal_password
GENERATED_HOST_DIR=./proyectos_generados
AI_MODEL=qwen2.5:0.5b
LEGACY_PROJECT_MODE=warn
LEGACY_PROJECT_AUTO_GONE=false

# Hardening (API security + CORS + env mode)
APP_ENV=dev
SECURITY_ENFORCED=false
SECURITY_API_KEY=change-me
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

