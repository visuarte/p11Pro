# Bridge Server Configuration
PORT=4000
NODE_ENV=development

# Database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=kolicode
POSTGRES_USER=kolicode
POSTGRES_PASSWORD=kolicode_dev_pass
DATABASE_URL=postgresql://kolicode:kolicode_dev_pass@127.0.0.1:5433/kolicode

# Redis
REDIS_URL=redis://localhost:6379
DIAGNOSTICS_DB_PATH=

# gRPC Services URLs
THUNDERKOLI_URL=localhost:3001
UNIVERSALENGINE_URL=localhost:8080
DESIGN_STUDIO_URL=localhost:8081

# Backup automation
BACKUP_DIR=../../backups
BACKUP_INTERVAL_SECONDS=600
BACKUP_RETENTION_COUNT=24

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SESSION_SECRET=your-super-secret-session-key-change-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=5000
