{
  "name": "@kolicode/bridge",
  "version": "0.1.0",
  "description": "KoliCode Bridge - API Gateway Layer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "grpc:generate": "find ../../shared/proto -name '._*' -delete && rm -rf src/grpc/generated && mkdir -p src/grpc/generated && proto-loader-gen-types --grpcLib=@grpc/grpc-js --longs=String --enums=String --defaults --oneofs -O src/grpc/generated -I ../../shared/proto -- ../../shared/proto/common.proto ../../shared/proto/bridge.proto ../../shared/proto/engine.proto ../../shared/proto/render.proto ../../shared/proto/diagnostic.proto && find src/grpc/generated -name '._*' -delete",
    "build": "npm run grpc:generate && tsc",
    "start": "node dist/index.js",
    "migrate:up": "node-pg-migrate -m src/db/migrations --database-url-var DATABASE_URL up",
    "migrate:down": "node-pg-migrate -m src/db/migrations --database-url-var DATABASE_URL down",
    "migrate:create": "node-pg-migrate -m src/db/migrations create",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "npm run grpc:generate && tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.14",
    "@grpc/proto-loader": "^0.7.10",
    "@seald-io/nedb": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
