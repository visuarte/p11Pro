# KoliCode - Docker Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_DB=kolicode
POSTGRES_USER=kolicode
POSTGRES_PASSWORD=kolicode_dev_pass
POSTGRES_PORT=5432

# PostgreSQL Connection String (for Node.js apps)
DATABASE_URL=postgresql://kolicode:kolicode_dev_pass@localhost:5432/kolicode

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# =============================================================================
# Application Environment
# =============================================================================
NODE_ENV=development

# =============================================================================
# Backend Services Ports (Uncomment when services are ready)
# =============================================================================
# THUNDERKOLI_PORT=3001
# UNIVERSALENGINE_PORT=8080
# BRIDGE_PORT=4000

# =============================================================================
# Security (Change these in production!)
# =============================================================================
# JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# =============================================================================
# External Services (Add when needed)
# =============================================================================
# OPENAI_API_KEY=your-openai-api-key
# STRIPE_API_KEY=your-stripe-api-key

# =============================================================================
# Logging and Monitoring
# =============================================================================
# LOG_LEVEL=info
# SENTRY_DSN=your-sentry-dsn

# =============================================================================
# Development Flags
# =============================================================================
# ENABLE_DEBUG=true
# ENABLE_SWAGGER=true

